}
.label-icon{font-size:13px}
.input-wrap{position:relative}
.input{
  width:100%;background:var(--bg3);
  border:1px solid var(--border2);
  border-radius:12px;padding:13px 16px;
  color:var(--text);font-size:14px;font-family:var(--sans);
  outline:none;transition:all 0.2s;
  position:relative;z-index:1;
}
.input:focus{
  border-color:var(--amber);
  box-shadow:0 0 0 3px var(--amber-dim),0 0 12px var(--amber-glow);
}
.input::placeholder{color:var(--hint)}
.input-prefix{
  position:absolute;left:14px;top:50%;transform:translateY(-50%);
  font-family:var(--mono);font-size:12px;color:var(--hint);z-index:2;pointer-events:none;
}
.has-prefix .input{padding-left:40px}

/* Error */
.error{
  display:flex;align-items:center;gap:8px;
  background:rgba(239,68,68,0.08);
  border:1px solid rgba(239,68,68,0.2);
  border-radius:10px;padding:10px 14px;
  color:#EF4444;font-size:13px;margin-bottom:20px;
}

/* Button */
.btn-submit{
  width:100%;padding:14px;border:none;border-radius:12px;
  background:linear-gradient(135deg,#F5A623,#E08A10);
