  box-shadow:0 0 0 1px rgba(255,255,255,0.02),0 24px 48px rgba(0,0,0,0.4);
  position:relative;overflow:hidden;
}
.card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(245,166,35,0.03) 0%,transparent 60%);
  pointer-events:none;
}

.card-head{margin-bottom:28px;position:relative}
